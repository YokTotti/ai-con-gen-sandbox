COMPOSE_PROJECT_NAME=acg-sandbox
# =============================================================================
# Claude Code Docker Environment - 環境変数設定
# このファイルを .env にコピーして値を設定してください
#   cp .env.example .env
# =============================================================================

# ---------------------------------------------------------------------------
# Claude Code 認証（以下の2つは排他。どちらか一方を選択）
# ---------------------------------------------------------------------------
#
# ■ 方法1: Max サブスクリプション（おすすめ）
#   → ANTHROPIC_API_KEY は空のままにする
#   → コンテナ内で `claude login` を実行し OAuth 認証
#   → トークンは ~/.claude/ の named volume に永続化される
#
# ■ 方法2: API キー（従量課金）
#   → https://console.anthropic.com/ で取得して以下に設定
#
# 注意: ANTHROPIC_API_KEY が設定されているとサブスクではなく
#       API 従量課金が優先されます
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=

# ---------------------------------------------------------------------------
# GitHub Token（任意 — gh CLI 認証用）
# https://github.com/settings/tokens で生成
# スコープ: repo, read:org, workflow
# 設定しない場合はコンテナ内で gh auth login を使用
# ---------------------------------------------------------------------------
GITHUB_TOKEN=

# ---------------------------------------------------------------------------
# ツールバージョン（デフォルト値は compose.yml で定義済み）
# ---------------------------------------------------------------------------
NODE_VERSION=22
GO_VERSION=1.25.0
PYTHON_VERSION=3.13
PNPM_VERSION=10
SWIFT_VERSION=6.1

# ---------------------------------------------------------------------------
# PostgreSQL 設定
# ---------------------------------------------------------------------------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=app_development
