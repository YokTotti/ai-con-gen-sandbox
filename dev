#!/usr/bin/env bash
# =============================================================================
# ./dev — Claude Code Docker インスタンス管理 CLI
#
# Usage:
#   ./dev create <type> <name>    インスタンス作成＋起動
#   ./dev connect <name> [cmd]    コンテナに接続（デフォルト: bash）
#   ./dev list                    全インスタンス一覧
#   ./dev rm <name> [--volumes]   インスタンス削除
#   ./dev purge-shared [vol ...]  共有ボリューム削除
#   ./dev start <name>            インスタンス起動
#   ./dev stop <name>             インスタンス停止
#   ./dev up                      全インスタンス一括起動
#   ./dev down                    全インスタンス一括停止
#   ./dev build [type]            イメージビルド
#   ./dev regenerate              compose.generated.yml 再生成
#   ./dev ps                      実行中コンテナの状態
#   ./dev auth-status [name]      Claude CLI 認証状態の確認
#   ./dev types                   利用可能なコンテナタイプ一覧
# =============================================================================

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REGISTRY="$SCRIPT_DIR/instances/registry.json"
COMPOSE_BASE="$SCRIPT_DIR/compose.yml"
COMPOSE_GENERATED="$SCRIPT_DIR/compose.generated.yml"

VALID_TYPES=("web-dev" "apple-dev" "sandbox")

# =============================================================================
# 前提チェック
# =============================================================================

check_deps() {
    if ! command -v jq &>/dev/null; then
        echo "Error: jq が必要です。brew install jq でインストールしてください。" >&2
        exit 1
    fi
    if ! command -v docker &>/dev/null; then
        echo "Error: docker が必要です。" >&2
        exit 1
    fi
}

# =============================================================================
# バリデーション
# =============================================================================

validate_name() {
    local name="$1"
    if [[ ! "$name" =~ ^[a-z0-9][a-z0-9-]*$ ]]; then
        echo "Error: インスタンス名は [a-z0-9][a-z0-9-]* のみ許可されます: '$name'" >&2
        exit 1
    fi
}

validate_type() {
    local type="$1"
    for t in "${VALID_TYPES[@]}"; do
        if [[ "$t" == "$type" ]]; then
            return 0
        fi
    done
    echo "Error: 不明なコンテナタイプ '$type'" >&2
    echo "利用可能なタイプ: ${VALID_TYPES[*]}" >&2
    exit 1
}

# =============================================================================
# レジストリ操作
# =============================================================================

ensure_registry() {
    if [[ ! -f "$REGISTRY" ]]; then
        mkdir -p "$(dirname "$REGISTRY")"
        echo '{"instances": {}}' > "$REGISTRY"
    fi
}

registry_get() {
    jq -r "$1" "$REGISTRY"
}

registry_add() {
    local name="$1" type="$2"
    local tmp
    tmp=$(mktemp)
    jq --arg name "$name" --arg type "$type" --arg created "$(date -u +%Y-%m-%dT%H:%M:%SZ)" \
        '.instances[$name] = {"type": $type, "created": $created}' "$REGISTRY" > "$tmp"
    mv "$tmp" "$REGISTRY"
}

registry_remove() {
    local name="$1"
    local tmp
    tmp=$(mktemp)
    jq --arg name "$name" 'del(.instances[$name])' "$REGISTRY" > "$tmp"
    mv "$tmp" "$REGISTRY"
}

instance_exists() {
    local name="$1"
    [[ "$(registry_get ".instances[\"$name\"] // empty")" != "" ]]
}

instance_type() {
    local name="$1"
    registry_get ".instances[\"$name\"].type"
}

# =============================================================================
# Docker Compose ラッパー
# =============================================================================

compose_cmd() {
    local -a files=(-f "$COMPOSE_BASE")
    if [[ -f "$COMPOSE_GENERATED" ]]; then
        files+=(-f "$COMPOSE_GENERATED")
    fi
    docker compose --project-directory "$SCRIPT_DIR" "${files[@]}" "$@"
}

# =============================================================================
# テンプレート: 各タイプの YAML 生成
# =============================================================================

generate_web_dev_service() {
    local name="$1"
    cat <<YAML
  ${name}:
    build:
      context: ./containers/web-dev
      args:
        NODE_VERSION: \${NODE_VERSION:-22}
        GO_VERSION: \${GO_VERSION:-1.25.0}
        PYTHON_VERSION: \${PYTHON_VERSION:-3.13}
        PNPM_VERSION: \${PNPM_VERSION:-10}
    image: acg-sandbox-web-dev
    container_name: acg-${name}
    hostname: ${name}
    stdin_open: true
    tty: true
    init: true
    environment:
      - ANTHROPIC_API_KEY=\${ANTHROPIC_API_KEY:-}
      - GITHUB_TOKEN=\${GITHUB_TOKEN:-}
      - DATABASE_URL=postgresql://\${POSTGRES_USER:-postgres}:\${POSTGRES_PASSWORD:-postgres}@postgres:5432/\${POSTGRES_DB:-app_development}
      - PGHOST=postgres
      - PGPORT=5432
      - PGUSER=\${POSTGRES_USER:-postgres}
      - PGPASSWORD=\${POSTGRES_PASSWORD:-postgres}
      - PGDATABASE=\${POSTGRES_DB:-app_development}
    volumes:
      - ${name}-project:/home/coder/project
      - shared-claude-config:/home/coder/.claude
      - shared-gh-config:/home/coder/.config/gh
      - ${name}-go-cache:/home/coder/go
      - ${name}-pnpm-store:/home/coder/.local/share/pnpm
      - ${name}-uv-cache:/home/coder/.cache/uv
    networks:
      - acg-sandbox-net
    depends_on:
      postgres:
        condition: service_healthy
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: unless-stopped
YAML
}

generate_apple_dev_service() {
    local name="$1"
    cat <<YAML
  ${name}:
    build:
      context: ./containers/apple-dev
      args:
        SWIFT_VERSION: \${SWIFT_VERSION:-6.1}
    image: acg-sandbox-apple-dev
    container_name: acg-${name}
    hostname: ${name}
    stdin_open: true
    tty: true
    init: true
    environment:
      - ANTHROPIC_API_KEY=\${ANTHROPIC_API_KEY:-}
      - GITHUB_TOKEN=\${GITHUB_TOKEN:-}
    volumes:
      - ${name}-project:/home/coder/project
      - shared-claude-config:/home/coder/.claude
      - shared-gh-config:/home/coder/.config/gh
    networks:
      - acg-sandbox-net
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: unless-stopped
YAML
}

generate_sandbox_service() {
    local name="$1"
    cat <<YAML
  ${name}:
    build:
      context: ./containers/sandbox
      args:
        NODE_VERSION: \${NODE_VERSION:-22}
        PYTHON_VERSION: \${PYTHON_VERSION:-3.13}
    image: acg-sandbox-sandbox
    container_name: acg-${name}
    hostname: ${name}
    stdin_open: true
    tty: true
    init: true
    environment:
      - ANTHROPIC_API_KEY=\${ANTHROPIC_API_KEY:-}
      - GITHUB_TOKEN=\${GITHUB_TOKEN:-}
    volumes:
      - ${name}-project:/home/coder/project
      - shared-claude-config:/home/coder/.claude
      - shared-gh-config:/home/coder/.config/gh
      - ${name}-uv-cache:/home/coder/.cache/uv
    networks:
      - acg-sandbox-net
    extra_hosts:
      - "host.docker.internal:host-gateway"
    restart: unless-stopped
